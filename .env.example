# UpPass Environment Variables
# Copy to .env and fill in values — NEVER commit .env to git

# ── Local (SQLite) ────────────────────────────────────────────────────────────
DATABASE_URL=sqlite:///./uppass.db

# ── GCP Cloud SQL (MySQL) ─────────────────────────────────────────────────────
# Local TCP (docker-compose):
# DATABASE_URL=mysql+pymysql://uppass:password@127.0.0.1:3306/uppass
# Cloud Run via Unix socket:
# DATABASE_URL=mysql+pymysql://uppass:password@/uppass?unix_socket=/cloudsql/PROJECT:REGION:INSTANCE

# ── Cryptographic secrets ─────────────────────────────────────────────────────
# Generate: python -c "import secrets; print(secrets.token_hex(32))"
# In GCP: store in Secret Manager, reference via Cloud Run --set-secrets
HMAC_SECRET=
DATA_ENCRYPTION_KEY=

# ── RSA private key path ──────────────────────────────────────────────────────
# Local: keys/private_v1.pem
# Cloud Run: /run/secrets/private_key  (mounted from Secret Manager)
PRIVATE_KEY_PATH=keys/private_v1.pem

# ── CORS ──────────────────────────────────────────────────────────────────────
# Local: http://localhost:3000
# GCP:   https://your-frontend-service-xxxx-uc.a.run.app
ALLOWED_ORIGINS=http://localhost:3000

# ── Runtime ───────────────────────────────────────────────────────────────────
ENV=development
